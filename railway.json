{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npm run build --workspace core && npm run build --workspace client && npm run build --workspace server"
  },
  "deploy": {
    "preDeployCommand": [
      "npm run prisma:migrate:deploy --workspace server"
    ],
    "startCommand": "npm run start --workspace server",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 300
  }
}
